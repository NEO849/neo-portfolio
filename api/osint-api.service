[Unit]
Description=Michael Fleps OSINT-API (FastAPI/Uvicorn)
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/bugbounty/neo-portfolio/api
ExecStart=/usr/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 8000 --workers 2 --log-level info
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=osint-api

# Sicherheitshärtung
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
